PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oralscan
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# S3-compatible object storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=ap-south-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=oralscan-images
S3_PUBLIC_BASE_URL=https://your-cdn-or-bucket-url

# AI cloud inference API
AI_INFERENCE_URL=https://your-ai-hosted-endpoint/predict
AI_INFERENCE_API_KEY=your-api-key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxx

# WhatsApp Cloud API (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAXXXXXXXXX
